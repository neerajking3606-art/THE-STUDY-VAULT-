<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — PW Batch Manager</title>
    <link rel="stylesheet" href="/stylesheets/3d-theme.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <style>
        .login-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 24px;
            padding: 4rem 3.2rem;
            backdrop-filter: blur(30px);
            animation: float 4s ease-in-out infinite;
        }

        .login-icon {
            width: 7rem;
            height: 7rem;
            border-radius: 20px;
            background: var(--gradient-main);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: white;
            margin: 0 auto 2.4rem;
            animation: pulse-glow 3s ease-in-out infinite;
        }

        .login-title {
            text-align: center;
            font-size: 2.6rem;
            font-weight: 800;
            margin-bottom: 0.6rem;
            background: linear-gradient(135deg, #fff, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .login-subtitle {
            text-align: center;
            font-size: 1.4rem;
            color: var(--text-secondary);
            margin-bottom: 3.2rem;
        }

        .input-group {
            position: relative;
            margin-bottom: 1.6rem;
        }

        .input-icon {
            position: absolute;
            left: 1.4rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.8rem;
            color: var(--text-muted);
        }

        .token-input {
            width: 100%;
            padding: 1.4rem 1.4rem 1.4rem 4.4rem;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            color: var(--text-primary);
            font-size: 1.4rem;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: all 0.3s ease;
        }

        .token-input:focus {
            border-color: var(--accent-purple);
            box-shadow: var(--glow-purple);
            background: rgba(124,58,237,0.08);
        }

        .token-input::placeholder {
            color: var(--text-muted);
        }

        .submit-btn {
            width: 100%;
            padding: 1.4rem;
            border-radius: 12px;
            border: none;
            background: var(--gradient-main);
            color: white;
            font-size: 1.6rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            margin-top: 0.8rem;
        }

        .submit-btn:hover {
            box-shadow: 0 0 40px rgba(124,58,237,0.5);
            transform: translateY(-2px);
        }

        .help-text {
            text-align: center;
            font-size: 1.2rem;
            color: var(--text-muted);
            margin-top: 2rem;
            line-height: 1.6;
        }

        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
        }
        .orb-1 { width: 500px; height: 500px; background: rgba(124,58,237,0.1); top: -150px; right: -100px; }
        .orb-2 { width: 350px; height: 350px; background: rgba(6,182,212,0.07); bottom: -80px; left: -80px; }
    </style>
    <script src="/javascripts/anti-devtools.js"></script>
<script src="/javascripts/global.js"></script>
</head>
<body>
    <canvas id="bg-canvas"></canvas>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <div class="page-content">
        <div class="login-page">
            <div class="login-card">
                <div class="login-icon">
                    <i class="ri-lock-password-line"></i>
                </div>
                <h1 class="login-title">Welcome Back</h1>
                <p class="login-subtitle">Enter your PW token to access your batches</p>

                <form method="post" action="/login">
                    <div class="input-group">
                        <i class="ri-key-2-line input-icon"></i>
                        <input
                            class="token-input"
                            type="text"
                            name="token"
                            placeholder="Paste your PW token here"
                            required
                            autocomplete="off"
                        >
                    </div>
                    <button class="submit-btn" type="submit">
                        <i class="ri-login-box-line"></i> Sign In
                    </button>
                </form>

                <p class="help-text">
                    Get your token from the PW app or website after logging in.
                </p>
            </div>
        </div>
    </div>

    <script src="/javascripts/3d-bg.js"></script>
</body>
</html>
